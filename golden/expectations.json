{
  "_description": "VLM benchmark golden set (synthetic demo). Replace with your own evidence to evaluate against your domain.",
  "_version": "demo-1.0",
  "_case": "Synthetic chat screenshots — based on real-world VLM evaluation methodology, but all PII redacted.",
  "_methodology": [
    "Amount precision (e.g. ¥1200.00; digit-shift like ¥120 / ¥12000 → FAIL)",
    "Named entity recall (people / orgs / products mentioned)",
    "Scene classification (communication / financial / contract / form)",
    "Key-fact extraction (transfer / reconciliation / agreement diff)",
    "Token-budget tracking (input + output) for cost monitoring",
    "TTFT + total latency for throughput baseline"
  ],
  "_token_budget": {
    "input_tokens_normal_range":  [600, 2800],
    "output_tokens_normal_range": [100, 900],
    "fail_if_output_truncated":   "eval_count == num_predict suggests possible truncation (FAIL warning)",
    "fail_if_output_too_short":   "output_tokens < 30 suggests model refusal / silent failure"
  },
  "_fixtures_note": "Place your own JPEG/PNG screenshots into fixtures/ matching the `image` keys below. The repo ships with no fixture data (privacy). See fixtures/README.md for guidance.",
